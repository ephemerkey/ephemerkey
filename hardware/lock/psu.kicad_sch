	(text "PWR — battery 1S + MT3608 boost.  Pinout / nets (PLACED, not wired).\nJ1 BAT 1S   1 = BAT+    2 = GND        (JST-PH; BAT+ also powers U1/MCU, and feeds DRV)\nU2 MT3608   1 SW    2 GND    3 FB    4 EN    5 IN    6 NC\nL1 10uH     BAT+ -- SW (U2.1)                       D2 SS34:  A = SW    K = VSOL(+12V)\nC3 10uF     1 = BAT+ (= U2 IN)   2 = GND            C4 22uF:  1 = VSOL   2 = GND\nR3 200k     VSOL -- FB                              (FB top)\nR4 22k      FB -- GND                               (FB base -> 6V)\nR17 20k     FB -- Q2.D                              (switched in -> 12V)\nQ2 AO3400   1 G = BOOST_VSEL   2 S = GND   3 D = R17    (FB switch: 6V <-> 12V)\nR2 100k     U2.EN -- GND                            R18 100k:  BOOST_VSEL -- GND   (default OFF / 6V)\nNETS IN:  U2.EN <- SOL_BOOST_EN (PA6) ;  BOOST_VSEL <- PA1.    OUT:  BAT+, VSOL -> DRV.\nVout = 0.6*(1 + R3/Rbot):  Rbot = R4 -> 6V ;  R4 || R17 (Q2 on) -> 12V."
		(exclude_from_sim no)
		(at 12 137.92 0)
		(effects
			(font
				(size 1.5 1.5)
			)
			(justify left top)
		)
		(uuid "40f69815-8d29-4615-848f-c17688d86356")
	)
